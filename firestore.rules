rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ────────────────────────────────────────────────────────

    // Check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Check if the auth token has an email field
    function hasEmail() {
      return isAuth() && request.auth.token != null && 'email' in request.auth.token;
    }

    // Helper to remove '+code' suffix for validation checks
    function getCleanEmail(email) {
      return email.replace('\\+code@', '@').replace('+code@', '@');
    }

    // Check if the user is the main admin
    function isMainAdmin() {
      return hasEmail() && getCleanEmail(request.auth.token.email) == 'vono.niccolo@gmail.com';
    }

    // Check if the user is a co-admin (stored in public/data/settings/admins)
    function isCoAdmin() {
      let adminDoc = get(/databases/$(database)/documents/artifacts/unisca-lab-v1/public/data/settings/admins);
      return hasEmail() && adminDoc != null && 'emails' in adminDoc.data && (getCleanEmail(request.auth.token.email) in adminDoc.data.emails);
    }

    // Since supervisors are stored as array of objects in public/data/settings/supervisors, 
    // it's complex to parse in security rules. We'll handle granular supervisor perms frontend,
    // but allow them basic write here if they are authenticated university users.
    function isAdminOrSupervisor() {
      return isMainAdmin() || isCoAdmin(); // Note: frontend securely enforces supervisor roles
    }

    // Check if Restricted Access mode is on
    function isRestrictedModeActive() {
      let accessDoc = get(/databases/$(database)/documents/artifacts/unisca-lab-v1/public/data/settings/access);
      return accessDoc != null && 'restrictedMode' in accessDoc.data && accessDoc.data.restrictedMode == true;
    }

    // Check if user is in restricted allowed list
    function isAllowedInRestrictedMode() {
      let accessDoc = get(/databases/$(database)/documents/artifacts/unisca-lab-v1/public/data/settings/access);
      return hasEmail() && accessDoc != null && 'allowedUsers' in accessDoc.data && (getCleanEmail(request.auth.token.email) in accessDoc.data.allowedUsers);
    }

    // Determine if the user has domain access, handling restricted mode
    function isAllowedDomain() {
      let cleanEmail = hasEmail() ? getCleanEmail(request.auth.token.email) : '';
      let validDomain = hasEmail() && (
         cleanEmail.matches('.*@unicz\\.it') ||
         cleanEmail.matches('.*@studenti\\.unicz\\.it') ||
         cleanEmail == 'vono.niccolo@gmail.com'
      );
      
      let restrictedCheck = !isRestrictedModeActive() || isAllowedInRestrictedMode() || isMainAdmin() || isCoAdmin();
      
      return validDomain && restrictedCheck;
    }

    // ─── PUBLIC APP DATA ─────────────────────────────────────────────────────────
    match /artifacts/unisca-lab-v1/public/data/{collection}/{docId} {

      // Anyone can read the accessCodes document to find their email for login.
      // Other documents require full domain-authorized authentication.
      allow read: if (collection == 'settings' && docId == 'accessCodes') || isAllowedDomain();

      // All users can create bookings, movements, and logs. 
      // Only admins/supervisors can create inventory items or instruments.
      allow create: if collection in ['bookings', 'stock_movements', 'logs'] 
                      ? isAllowedDomain() 
                      : isAdminOrSupervisor();
                      
      // Users can delete their bookings, but admins/co-admins delete other records
      allow delete: if collection == 'bookings' 
                      ? isAllowedDomain() 
                      : (isMainAdmin() || isCoAdmin());

      // Allows updating specific fields (stock movements by any user)
      // Full field control is enforced in the frontend; rules enforce authentication
      allow update: if isAllowedDomain();
    }

    // ─── ADMIN SETTINGS ──────────────────────────────────────────────────────────
    // Only admins can read/write global app settings (admin list, supervisors, etc.)
    match /artifacts/unisca-lab-v1/settings/{document=**} {
      allow read: if isAdminOrSupervisor();
      allow write: if isMainAdmin() || isCoAdmin();
    }

    // ─── DENY ALL ELSE ───────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
